PORT=4000
CLIENT_ORIGIN=http://localhost:5173
LOG_LEVEL=info

DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Auth
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN=30d

# Email (Resend free tier)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM="Scrabble Game <onboarding@resend.dev>"

# Google OAuth (optional — can be left blank)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# URL of the running client (used in email links and OAuth post-redirect)
CLIENT_URL=http://localhost:5173